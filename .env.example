# Copy to .env and fill in (never commit .env)
# Get a key at https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Supabase (Expo: EXPO_PUBLIC_* are available in the app)
# Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-side only (scripts like npm run db:push:exa) — never expose in the mobile app
SUPABASE_SERVICE_ROLE_KEY=

# Alternative for db:push:exa: Prisma-style Postgres URL (pooler or direct) from Supabase
# DATABASE_URL=
# DIRECT_URL=

# Optional: backend port (default 4000)
# PORT=4000
